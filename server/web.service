[Unit]
Description=Volleyball App Frontend
After=network.target

[Service]
User=floindil
Group=floindil
WorkingDirectory=/home/floindil/vapp/TableMaker2/frontend/web
ExecStart=/home/floindil/vapp/TableMaker2/.venv/bin/python -m http.server 5500
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target